---
const year = new Date().getFullYear();

const cols = [
  {
    heading: 'Servicios',
    links: [
      { label: 'Identidad de Marca', href: '/servicios#identidad' },
      { label: 'Presencia Digital', href: '/servicios#presencia' },
      { label: 'Migración de Datos', href: '/servicios#datos' },
      { label: 'Automatización IA', href: '/servicios#automatizacion' },
      { label: 'Agentes Inteligentes', href: '/servicios#inteligencia' },
      { label: 'Escala & White Label', href: '/servicios#escala' },
    ],
  },
  {
    heading: 'Empresa',
    links: [
      { label: 'Sobre BIE', href: '/sobre-bie' },
      { label: 'Casos reales', href: '/casos/island-estates' },
      { label: 'Modelo Satélites', href: '/satelites' },
      { label: 'Contacto', href: '/contacto' },
    ],
  },
  {
    heading: 'Contacto',
    links: [
      { label: '+593 99 882 5303', href: 'https://wa.me/593998825303', external: true },
      { label: 'hola@bie.ec', href: 'mailto:hola@bie.ec', external: true },
      { label: 'Guayaquil, Ecuador', href: '#', external: false },
    ],
  },
];
---

<footer
  style="
    background: var(--color-bie-blue);
    color: white;
  "
  role="contentinfo"
>
  <div class="ctn" style="padding-top: 4rem; padding-bottom: 4rem;">

    <!-- Grid: brand col + 3 link cols -->
    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      margin-bottom: 3.5rem;
    " class="footer-grid">

      <!-- Brand col -->
      <div>
        <a href="/" aria-label="BIE inicio" style="display:inline-block; margin-bottom:1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 33" width="100" height="33" aria-label="BIE">
            <text x="0" y="26" font-family="Arial Black,Arial,sans-serif" font-weight="900" font-size="28" fill="white" letter-spacing="-1">BIE</text>
            <text x="56" y="26" font-family="Arial,sans-serif" font-weight="400" font-size="10" fill="rgba(255,255,255,0.4)" letter-spacing="0.5">®</text>
          </svg>
        </a>
        <p style="font-size:0.875rem; color:rgba(255,255,255,0.55); line-height:1.7; max-width:240px;">
          Construimos ecosistemas de IA para PyMEs en Ecuador y Latinoamérica.
        </p>
        <!-- Social icons -->
        <div style="display:flex; gap:0.625rem; margin-top:1.25rem;">
          <a
            href="https://linkedin.com/company/bie-ec"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn BIE"
            style="
              width:36px; height:36px; border-radius:8px;
              background: rgba(255,255,255,0.1);
              display:flex; align-items:center; justify-content:center;
              color: rgba(255,255,255,0.6);
              transition: background 0.15s, color 0.15s;
              min-width:44px; min-height:44px;
            "
            class="social-icon"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="https://wa.me/593998825303"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp BIE"
            style="
              width:36px; height:36px; border-radius:8px;
              background: rgba(255,255,255,0.1);
              display:flex; align-items:center; justify-content:center;
              color: rgba(255,255,255,0.6);
              transition: background 0.15s, color 0.15s;
              min-width:44px; min-height:44px;
            "
            class="social-icon"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm.029 18.88a7.945 7.945 0 01-3.793-.965l-4.205 1.104 1.126-4.111a7.955 7.955 0 01-1.063-3.969C4.094 7.067 7.748 3.413 12.029 3.413c4.281 0 7.935 3.654 7.935 7.935-.001 4.282-3.654 7.532-7.935 7.532z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link cols -->
      {cols.map(col => (
        <div>
          <p style="font-size:0.6875rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:1rem;">
            {col.heading}
          </p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.625rem;" role="list">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                  style="font-size:0.875rem; color:rgba(255,255,255,0.55); transition:color 0.15s; text-decoration:none;"
                  class="footer-link"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

    </div>

    <!-- Bottom bar -->
    <div style="
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    " class="footer-bottom">
      <p style="font-size:0.75rem; color:rgba(255,255,255,0.3);">
        &copy; {year} BIE Business Intelligence Enhancer. Todos los derechos reservados.
      </p>
      <div style="display:flex; gap:1.5rem;">
        <a href="/privacidad" style="font-size:0.75rem; color:rgba(255,255,255,0.3); transition:color 0.15s; text-decoration:none;" class="footer-link">Privacidad</a>
        <a href="/terminos"   style="font-size:0.75rem; color:rgba(255,255,255,0.3); transition:color 0.15s; text-decoration:none;" class="footer-link">Términos</a>
      </div>
    </div>

  </div>
</footer>

<style>
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1fr 1fr !important; }
    .footer-bottom { flex-direction: row !important; align-items: center !important; justify-content: space-between !important; }
  }
  .footer-link:hover { color: white !important; }
  .social-icon:hover { background: rgba(255,255,255,0.18) !important; color: white !important; }
</style>
