---
const points = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    heading: 'Procesos manuales que consumen tiempo',
    body: 'Tu equipo dedica horas a tareas repetitivas que un agente IA podría ejecutar en segundos, con más consistencia y sin errores.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="10"/></svg>`,
    heading: 'IA cuesta caro y tarda demasiado',
    body: 'Los proyectos tradicionales de transformación digital duran 6-12 meses y requieren equipos técnicos que no tienes — o no quieres mantener.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3h18v18H3z"/><path d="M3 9h18M9 21V9"/></svg>`,
    heading: 'Agencias entregan, no operan',
    body: 'Te entregaron un software. Pero nadie lo opera, nadie lo mantiene y nadie mide si realmente funciona para tu negocio.',
  },
];
---

<section
  style="background: var(--color-bg-secondary);"
  class="sec"
  aria-labelledby="problem-heading"
>
  <div class="ctn">

    <div style="max-width: var(--width-prose); margin-bottom: 3.5rem;" data-fade>
      <span class="tag">El problema que resolvemos</span>
      <h2 id="problem-heading" class="t-h2" style="color:var(--color-text-primary); margin-bottom:1rem;">
        La brecha entre querer IA y tenerla funcionando
      </h2>
      <p style="font-size:1.125rem; color:var(--color-text-secondary); line-height:1.7;">
        Los negocios pierden tiempo y dinero en procesos manuales que un equipo de IA
        podría ejecutar mejor. BIE existe para cerrar esa brecha: tecnología de élite,
        implementación quirúrgica, operación garantizada.
      </p>
    </div>

    <!-- 3-card grid -->
    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
    " class="problem-grid">
      {points.map((p, i) => (
        <article
          class="card"
          style="padding: 1.75rem;"
          data-fade
          data-delay={String(i * 100)}
        >
          <div style="
            width: 48px; height: 48px; border-radius: 12px;
            background: rgba(27,58,92,0.07);
            display: flex; align-items: center; justify-content: center;
            color: var(--color-bie-accent);
            margin-bottom: 1.25rem;
            flex-shrink: 0;
          " set:html={p.icon}></div>
          <h3 style="font-size:1.0625rem; font-weight:600; color:var(--color-text-primary); margin-bottom:0.625rem; letter-spacing:-0.01em;">
            {p.heading}
          </h3>
          <p style="font-size:0.9375rem; color:var(--color-text-secondary); line-height:1.65;">
            {p.body}
          </p>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  @media (min-width: 768px) {
    .problem-grid { grid-template-columns: repeat(3, 1fr) !important; }
  }
</style>
