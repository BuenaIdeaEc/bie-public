<section
  id="hero"
  style="
    position: relative;
    background: #000000;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  "
>
  <!-- Canvas: square particles + connections -->
  <canvas id="hero-canvas" aria-hidden="true" style="position:absolute; inset:0; width:100%; height:100%;"></canvas>

  <!-- Pixel grid (brand texture) -->
  <div aria-hidden="true" style="
    position:absolute; inset:0; pointer-events:none;
    background-image:
      linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
    background-size: 40px 40px;
  "></div>

  <!-- Ghost square elements (brand mark motif) -->
  <div aria-hidden="true" style="position:absolute; top:10%; right:6%; width:180px; height:180px; border:1px solid rgba(255,255,255,0.06); pointer-events:none;"></div>
  <div aria-hidden="true" style="position:absolute; top:calc(10% + 180px); right:6%; width:180px; height:180px; border:1px solid rgba(255,255,255,0.04); pointer-events:none;"></div>
  <div aria-hidden="true" style="position:absolute; top:calc(10% + 40px); right:calc(6% + 180px); width:40px; height:40px; background:rgba(255,255,255,0.05); pointer-events:none;"></div>
  <div aria-hidden="true" style="position:absolute; top:calc(10% + 80px); right:calc(6% + 180px); width:40px; height:40px; background:rgba(255,255,255,0.03); pointer-events:none;"></div>

  <!-- Edge vignette -->
  <div aria-hidden="true" style="
    position:absolute; inset:0; pointer-events:none;
    background: radial-gradient(ellipse 110% 90% at 50% 50%, transparent 35%, rgba(0,0,0,0.55) 100%);
  "></div>

  <!-- BIE giant watermark (brand mark ghost) -->
  <div aria-hidden="true" class="bie-watermark">BIE</div>

  <!-- Bottom fade to white -->
  <div aria-hidden="true" style="
    position:absolute; bottom:0; left:0; right:0; height:180px; pointer-events:none;
    background: linear-gradient(to bottom, transparent, #ffffff);
  "></div>

  <!-- Content -->
  <div class="ctn hero-content">

    <!-- Badge -->
    <div class="hero-badge" data-fade>
      <span class="hero-badge-dot" aria-hidden="true"></span>
      Ecosistemas de Agentes IA · Ecuador
    </div>

    <!-- Hook — oversized, commands attention -->
    <h1 class="hero-h1" data-fade data-delay="60">
      No somos<br>una agencia.
    </h1>

    <!-- Gold divider -->
    <div class="hero-divider" aria-hidden="true" data-fade data-delay="90"></div>

    <!-- Subheadline — tight, impactful -->
    <p class="hero-sub" data-fade data-delay="130">
      Las agencias de entrega no operan.<br>
      Nosotros construimos los sistemas que trabajan<br>
      <strong>mientras tu empresa duerme.</strong>
    </p>

    <!-- Three contrasts — ultra-minimal, no bullets -->
    <div class="hero-contrasts" data-fade data-delay="180">
      <span>Agencias entregan y se van — nosotros operamos.</span>
      <span>Agencias cobran por proyecto — nosotros medimos en resultados.</span>
      <span>Agencias construyen — nosotros construimos, operamos y escalamos.</span>
    </div>

    <!-- CTAs -->
    <div class="hero-ctas" data-fade data-delay="230">
      <a href="#diag-form" class="btn hero-btn-primary">
        Solicitar diagnóstico gratuito
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#value-chain" class="btn btn-outline-white hero-btn-secondary">
        Ver cómo funciona
      </a>
    </div>

    <!-- Trust -->
    <p class="hero-trust" data-fade data-delay="270">
      Sin costo &nbsp;·&nbsp; Sin compromiso &nbsp;·&nbsp; Respuesta en menos de 24 horas
    </p>

  </div>

  <!-- Scroll indicator -->
  <a href="#value-chain" aria-label="Ver siguiente sección" class="hero-scroll-btn">
    <svg class="hero-bounce" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<style>
  /* ── Hero layout ── */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
    padding-bottom: 11rem;
    max-width: 900px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.875rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 2.25rem;
  }
  .hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-bie-gold); flex-shrink: 0;
  }

  /* H1 — commanding, large */
  .hero-h1 {
    font-size: clamp(3.25rem, 9vw, 7rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: white;
    margin-bottom: 1.5rem;
  }

  /* Gold line */
  .hero-divider {
    width: 36px; height: 2px;
    background: var(--color-bie-gold);
    border-radius: 99px;
    margin-bottom: 1.5rem;
  }

  /* Subheadline */
  .hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    color: rgba(255,255,255,0.5);
    line-height: 1.65;
    max-width: 44ch;
    margin-bottom: 2rem;
  }
  .hero-sub strong { color: rgba(255,255,255,0.82); font-weight: 600; }

  /* Contrasts — minimal, no bullets */
  .hero-contrasts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2.75rem;
  }
  .hero-contrasts span {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.32);
    padding-left: 1rem;
    border-left: 1.5px solid rgba(255,255,255,0.1);
    line-height: 1.5;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.75rem;
  }
  .hero-btn-primary {
    background: white !important;
    color: #000 !important;
    font-weight: 700 !important;
    padding: 0.875rem 1.875rem !important;
    min-height: 52px !important;
    font-size: 0.9375rem !important;
    transition: box-shadow 0.2s, transform 0.15s !important;
  }
  .hero-btn-primary:hover {
    box-shadow: 0 0 48px rgba(255,255,255,0.15) !important;
    transform: translateY(-1px) !important;
  }
  .hero-btn-secondary {
    padding: 0.875rem 1.625rem !important;
    min-height: 52px !important;
    font-size: 0.9375rem !important;
  }

  /* Trust */
  .hero-trust {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.18);
  }

  /* BIE watermark */
  .bie-watermark {
    position: absolute;
    right: -4vw;
    bottom: 5%;
    font-size: clamp(180px, 38vw, 560px);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: rgba(255,255,255,0.022);
    user-select: none;
    pointer-events: none;
    z-index: 0;
    font-family: 'Inter', 'Arial Black', Arial, sans-serif;
  }

  /* Scroll btn */
  .hero-scroll-btn {
    position: absolute;
    bottom: 6.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: rgba(255,255,255,0.18);
    transition: color 0.2s;
  }
  .hero-scroll-btn:hover { color: rgba(255,255,255,0.4); }
  .hero-bounce { animation: hbounce 2.2s ease-in-out infinite; }
  @keyframes hbounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(7px); }
  }

  @media (max-width: 640px) {
    .hero-content { padding-top: 7rem; padding-bottom: 9rem; }
    .bie-watermark { font-size: 52vw; right: -6vw; }
  }
</style>

<script>
  document.body.classList.add('hero-dark');

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && !prefersReduced) {
    const ctx = canvas.getContext('2d')!;
    const mobile = window.innerWidth < 640;
    const COUNT = mobile ? 55 : 130;
    const MAX_D = mobile ? 110 : 150;

    interface Pt {
      x: number; y: number; vx: number; vy: number;
      s: number; // half-size of square
      gold: boolean;
      rot: number; rotV: number;
    }

    let pts: Pt[] = [];
    const mouse = { x: -9999, y: -9999 };
    let raf = 0;
    let W = 0, H = 0;

    function init() {
      W = canvas!.width = canvas!.offsetWidth;
      H = canvas!.height = canvas!.offsetHeight;
      pts = Array.from({ length: COUNT }, () => ({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.7,
        vy: (Math.random() - 0.5) * 0.7,
        s: Math.random() * 2 + 1,
        gold: Math.random() < 0.1,
        rot: Math.random() * Math.PI * 2,
        rotV: (Math.random() - 0.5) * 0.015,
      }));
    }

    function frame() {
      ctx.clearRect(0, 0, W, H);

      // Draw connection lines
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x;
          const dy = pts[i].y - pts[j].y;
          const d = Math.hypot(dx, dy);
          if (d < MAX_D) {
            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.strokeStyle = `rgba(255,255,255,${(1 - d / MAX_D) * 0.16})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      // Draw squares
      pts.forEach(p => {
        // Mouse repulsion/attraction (desktop)
        if (!mobile) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const d = Math.hypot(dx, dy);
          if (d < 200) {
            p.vx += dx * 0.00010;
            p.vy += dy * 0.00010;
          }
          const spd = Math.hypot(p.vx, p.vy);
          if (spd > 1.8) { p.vx = p.vx / spd * 1.8; p.vy = p.vy / spd * 1.8; }
        }

        p.x += p.vx; p.y += p.vy;
        p.rot += p.rotV;
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;

        // Draw rotated square
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.fillStyle = p.gold ? 'rgba(196,151,42,0.55)' : 'rgba(255,255,255,0.28)';
        ctx.fillRect(-p.s, -p.s, p.s * 2, p.s * 2);
        ctx.restore();
      });

      raf = requestAnimationFrame(frame);
    }

    if (!mobile) {
      document.getElementById('hero')!.addEventListener('mousemove', e => {
        const r = canvas!.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      });
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else raf = requestAnimationFrame(frame);
    });
    window.addEventListener('resize', init, { passive: true });
    init();
    raf = requestAnimationFrame(frame);
  }
</script>
