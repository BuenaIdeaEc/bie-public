---
---

<section
  id="hero"
  style="
    position: relative;
    background: #000000;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  "
>
  <!-- Particle canvas -->
  <canvas
    id="hero-canvas"
    aria-hidden="true"
    style="position:absolute; inset:0; width:100%; height:100%;"
  ></canvas>

  <!-- Pixel grid — brand texture (white grid lines + square accents) -->
  <div
    aria-hidden="true"
    style="
      position:absolute; inset:0; pointer-events:none;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
    "
  ></div>
  <!-- Pixel accent squares (brand identity) -->
  <div aria-hidden="true" style="position:absolute; top:18%; right:12%; width:12px; height:12px; background:rgba(255,255,255,0.12); pointer-events:none;"></div>
  <div aria-hidden="true" style="position:absolute; top:calc(18% + 40px); right:12%; width:12px; height:12px; background:rgba(255,255,255,0.06); pointer-events:none;"></div>
  <div aria-hidden="true" style="position:absolute; top:18%; right:calc(12% + 40px); width:12px; height:12px; background:rgba(255,255,255,0.06); pointer-events:none;"></div>

  <!-- Edge vignette -->
  <div
    aria-hidden="true"
    style="
      position:absolute; inset:0; pointer-events:none;
      background: radial-gradient(ellipse 120% 100% at 50% 50%, transparent 40%, rgba(0,0,0,0.45) 100%);
    "
  ></div>

  <!-- Bottom fade to white -->
  <div
    aria-hidden="true"
    style="
      position:absolute; bottom:0; left:0; right:0; height:160px; pointer-events:none;
      background: linear-gradient(to bottom, transparent, #ffffff);
    "
  ></div>

  <!-- Content -->
  <div
    class="ctn"
    style="position:relative; z-index:1; text-align:center; padding-top:7rem; padding-bottom:10rem;"
  >

    <!-- Badge -->
    <div
      style="
        display:inline-flex; align-items:center; gap:0.5rem;
        padding:0.375rem 1rem; border-radius:999px;
        background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);
        font-size:0.75rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;
        color:rgba(255,255,255,0.5); margin-bottom:2.5rem;
      "
      data-fade
    >
      <span style="width:6px; height:6px; border-radius:50%; background:var(--color-bie-gold); flex-shrink:0;" aria-hidden="true"></span>
      Ecosistemas de Agentes IA · Ecuador
    </div>

    <!-- Main hook -->
    <h1
      class="t-display"
      style="color:white; margin-bottom:1.25rem; max-width:16ch; margin-inline:auto;"
      data-fade
      data-delay="80"
    >
      No somos<br>una agencia.
    </h1>

    <!-- Gold accent line -->
    <div
      style="width:40px; height:2.5px; background:var(--color-bie-gold); border-radius:99px; margin:1.5rem auto;"
      aria-hidden="true"
      data-fade
      data-delay="110"
    ></div>

    <!-- Subheadline -->
    <p
      style="
        font-size:clamp(1.0625rem, 2.5vw, 1.3125rem);
        color:rgba(255,255,255,0.55); line-height:1.7;
        max-width:46ch; margin:0 auto 2.5rem;
      "
      data-fade
      data-delay="150"
    >
      Las agencias de entrega no operan.<br>
      Nosotros construimos los sistemas que trabajan<br>
      <strong style="color:rgba(255,255,255,0.85);">mientras tu empresa duerme.</strong>
    </p>

    <!-- Contrast points -->
    <div
      style="display:inline-flex; flex-direction:column; align-items:flex-start; gap:0.75rem; margin-bottom:3rem;"
      data-fade
      data-delay="195"
    >
      {[
        'Agencias entregan y se van — nosotros operamos cada día.',
        'Agencias cobran por proyecto — nosotros medimos en resultados.',
        'Agencias construyen — nosotros construimos, operamos y escalamos.',
      ].map(point => (
        <div style="display:flex; align-items:center; gap:0.875rem; font-size:0.9375rem; color:rgba(255,255,255,0.42);">
          <span style="width:4px; height:4px; border-radius:50%; background:var(--color-bie-gold); flex-shrink:0;" aria-hidden="true"></span>
          {point}
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div
      style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center; margin-bottom:2rem;"
      data-fade
      data-delay="240"
    >
      <a
        href="#diag-form"
        class="btn hero-cta-primary"
        style="
          background:white; color:#06090F; font-weight:700;
          padding:0.875rem 2rem; font-size:0.9375rem; min-height:52px;
          transition:box-shadow 0.2s, transform 0.15s;
        "
      >
        Solicitar diagnóstico gratuito
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a
        href="#value-chain"
        class="btn btn-outline-white"
        style="padding:0.875rem 1.75rem; font-size:0.9375rem; min-height:52px;"
      >
        Ver cómo funciona
      </a>
    </div>

    <!-- Trust microcopy -->
    <p style="font-size:0.8125rem; color:rgba(255,255,255,0.22);" data-fade data-delay="280">
      Sin costo &nbsp;·&nbsp; Sin compromiso &nbsp;·&nbsp; Respuesta en menos de 24 horas
    </p>

  </div>

  <!-- Scroll indicator -->
  <a
    href="#value-chain"
    aria-label="Ver siguiente sección"
    style="
      position:absolute; bottom:7rem; left:50%; transform:translateX(-50%);
      z-index:1; color:rgba(255,255,255,0.2); transition:color 0.2s;
    "
    class="scroll-down-btn"
  >
    <svg class="bounce-arrow" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<style>
  .bounce-arrow { animation: hero-bounce 2.2s ease-in-out infinite; }
  @keyframes hero-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(7px); }
  }
  .scroll-down-btn:hover { color: rgba(255,255,255,0.45) !important; }
  .hero-cta-primary:hover {
    box-shadow: 0 0 48px rgba(255,255,255,0.14) !important;
    transform: translateY(-1px) !important;
  }
</style>

<script>
  document.body.classList.add('hero-dark');

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && !prefersReduced) {
    const ctx = canvas.getContext('2d')!;
    const mobile = window.innerWidth < 640;
    const COUNT = mobile ? 45 : 85;
    const MAX_D = mobile ? 100 : 140;

    interface Pt { x: number; y: number; vx: number; vy: number; r: number; gold: boolean; }

    let pts: Pt[] = [];
    const mouse = { x: -9999, y: -9999 };
    let raf = 0;
    let W = 0, H = 0;

    function init() {
      W = canvas!.width = canvas!.offsetWidth;
      H = canvas!.height = canvas!.offsetHeight;
      pts = Array.from({ length: COUNT }, () => ({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.65,
        vy: (Math.random() - 0.5) * 0.65,
        r: Math.random() * 1.6 + 0.5,
        gold: Math.random() < 0.1,
      }));
    }

    function frame() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x;
          const dy = pts[i].y - pts[j].y;
          const d = Math.hypot(dx, dy);
          if (d < MAX_D) {
            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.strokeStyle = `rgba(255,255,255,${(1 - d / MAX_D) * 0.18})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      pts.forEach(p => {
        if (!mobile) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const d = Math.hypot(dx, dy);
          if (d < 180) { p.vx += dx * 0.00012; p.vy += dy * 0.00012; }
          const spd = Math.hypot(p.vx, p.vy);
          if (spd > 1.8) { p.vx = p.vx / spd * 1.8; p.vy = p.vy / spd * 1.8; }
        }
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.gold ? 'rgba(196,151,42,0.6)' : 'rgba(255,255,255,0.3)';
        ctx.fill();
      });
      raf = requestAnimationFrame(frame);
    }

    if (!mobile) {
      document.getElementById('hero')!.addEventListener('mousemove', (e) => {
        const r = canvas!.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      });
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else raf = requestAnimationFrame(frame);
    });
    window.addEventListener('resize', init, { passive: true });
    init();
    raf = requestAnimationFrame(frame);
  }
</script>
