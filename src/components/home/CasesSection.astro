---
import { caseStudies } from '../../data/cases.ts';
---

<section
  style="background: var(--color-bg-primary);"
  class="sec"
  aria-labelledby="cases-heading"
>
  <div class="ctn">

    <!-- Header -->
    <div class="cs-header" data-fade>
      <span class="tag">Proyectos en producción</span>
      <h2 id="cases-heading" class="cs-h2">
        No vendemos teoría.<br>Vendemos lo que ya<br>tenemos funcionando.
      </h2>
    </div>

    <!-- Case rows -->
    <div class="cs-rows" role="list">
      {caseStudies.map((c, i) => (
        <a
          href={c.href}
          class="cs-row"
          role="listitem"
          data-fade
          data-delay={String(i * 80)}
          aria-label={`Ver caso ${c.client}`}
        >
          <!-- Thumbnail -->
          <div class="cs-thumb" aria-hidden="true">
            <img
              src={c.cover}
              alt=""
              loading="lazy"
              width="220"
              height="130"
            />
            {c.status === 'development' && (
              <span class="cs-thumb-badge">En desarrollo</span>
            )}
          </div>

          <!-- Metric -->
          <div class="cs-metric" aria-label={`${c.metric} ${c.metricLabel}`}>
            <span class="cs-metric-val">{c.metric}</span>
            <span class="cs-metric-lbl">{c.metricLabel}</span>
          </div>

          <!-- Client info -->
          <div class="cs-info">
            <p class="cs-industry">{c.industry}</p>
            <h3 class="cs-client">{c.client}</h3>
            <p class="cs-headline">{c.headline}</p>
          </div>

          <!-- Arrow -->
          <span class="cs-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- See all link -->
    <div style="margin-top:2.5rem; text-align:center;" data-fade>
      <a href="/casos/island-estates" style="font-size:0.9375rem; font-weight:500; color:var(--color-bie-accent); text-decoration:none;">
        Ver todos los casos →
      </a>
    </div>

  </div>
</section>

<style>
  .cs-header {
    max-width: 520px;
    margin-bottom: 3.5rem;
  }

  .cs-h2 {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text-primary);
    margin-top: 0.75rem;
  }

  .cs-rows { display: flex; flex-direction: column; }

  .cs-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .cs-rows .cs-row:first-child { border-top: 1px solid var(--color-border); }

  /* Thumbnail */
  .cs-thumb {
    display: none;
    position: relative;
    border-radius: 0.375rem;
    overflow: hidden;
    flex-shrink: 0;
    width: 220px;
    height: 130px;
    background: var(--color-bg-secondary);
  }
  .cs-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .cs-row:hover .cs-thumb img {
    transform: scale(1.04);
  }
  .cs-thumb-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(196,151,42,0.9);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  .cs-metric {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .cs-metric-val {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-bie-blue);
  }

  .cs-metric-lbl {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
    max-width: 120px;
  }

  .cs-info { min-width: 0; }

  .cs-industry {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 0.25rem;
  }

  .cs-client {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.015em;
    margin-bottom: 0.25rem;
  }

  .cs-headline {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .cs-arrow {
    display: none;
    align-items: center;
    color: var(--color-bie-accent);
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    align-self: center;
  }

  /* Desktop layout */
  @media (min-width: 768px) {
    .cs-thumb { display: block; }

    .cs-row {
      grid-template-columns: 220px 10rem 1fr auto;
      gap: 0 2.5rem;
      align-items: center;
      padding: 2rem 0;
    }
    .cs-metric { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .cs-metric-val { font-size: clamp(2rem, 4vw, 3rem); }
    .cs-arrow { display: flex; opacity: 0; }
    .cs-row:hover .cs-arrow { opacity: 1; transform: translateX(6px); }
  }
</style>
