---
import { valueLayers } from '../../data/services.ts';

const icons: Record<string, string> = {
  fingerprint: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 4"/><path d="M5 19.5C5.5 18 6 15 6 12c0-2 .5-4 2-5.5"/><path d="M13 22c1-2 2-4 2-6 0-2.5-1-4.5-3-5.5"/><path d="M8 22c0-3 0-6 2-8"/><path d="M19 14c-.5 2-1.5 4-2 6"/><path d="M22 12c0 4-1 7-3 9"/><circle cx="12" cy="12" r="2"/></svg>`,
  globe: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  database: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
  zap: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  brain: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>`,
  'trending-up': `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.5 8.5-5-5L2 17"/><path d="M16 7h6v6"/></svg>`,
};

const layerBgColors = [
  'rgba(196,151,42,0.1)',  // gold tint
  'rgba(46,117,182,0.1)',  // blue tint
  'rgba(27,58,92,0.08)',   // navy tint
  'rgba(239,68,68,0.08)',  // red tint
  'rgba(16,185,129,0.08)', // green tint
  'rgba(107,114,128,0.08)', // gray tint
];
const layerIconColors = [
  'var(--color-bie-gold)',
  'var(--color-bie-accent)',
  'var(--color-bie-blue)',
  '#EF4444',
  '#10B981',
  '#6B7280',
];
---

<section
  id="value-chain"
  style="background: var(--color-bg-primary);"
  class="sec"
  aria-labelledby="value-chain-heading"
>
  <div class="ctn">

    <!-- Header -->
    <div style="text-align:center; max-width:640px; margin:0 auto 3.5rem;" data-fade>
      <span class="tag">Cómo construimos tu ventaja</span>
      <h2 id="value-chain-heading" class="t-h2" style="color:var(--color-text-primary); margin-bottom:1rem;">
        Seis capas. Tu empresa entra donde está.
      </h2>
      <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.7;">
        No necesitas todo al mismo tiempo. Activamos las capas que tienen sentido para tu negocio ahora, en el orden correcto.
      </p>
    </div>

    <!-- 6-card grid -->
    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    " class="chain-grid">
      {valueLayers.map((layer, i) => (
        <article
          class="card chain-card"
          style="padding: 1.625rem; cursor:default;"
          data-fade
          data-delay={String(i * 60)}
        >
          <!-- Number + icon row -->
          <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:1.125rem;">
            <span style="font-size:0.6875rem; font-weight:700; letter-spacing:0.12em; color:var(--color-text-tertiary); text-transform:uppercase;">
              {layer.number}
            </span>
            <div
              class="layer-icon"
              style={`
                width:42px; height:42px; border-radius:10px;
                background: ${layerBgColors[i]};
                display:flex; align-items:center; justify-content:center;
                color: ${layerIconColors[i]};
                transition: background 0.2s, color 0.2s;
                flex-shrink:0;
              `}
              set:html={icons[layer.icon]}
            ></div>
          </div>

          <!-- Layer name -->
          <p style="font-size:0.6875rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-bie-accent); margin-bottom:0.375rem;">
            {layer.name}
          </p>

          <!-- Tagline -->
          <h3 style="font-size:1rem; font-weight:600; color:var(--color-text-primary); line-height:1.35; margin-bottom:0.875rem; letter-spacing:-0.01em;">
            {layer.tagline}
          </h3>

          <!-- Product pills -->
          <div style="display:flex; flex-wrap:wrap; gap:0.375rem; margin-bottom:1rem;">
            {layer.products.map(p => (
              <span style="
                padding: 0.25rem 0.625rem;
                border-radius: 999px;
                background: var(--color-bg-secondary);
                font-size: 0.75rem; font-weight:500;
                color: var(--color-text-secondary);
              ">
                {p}
              </span>
            ))}
          </div>

          <!-- Hover link -->
          <a
            href={`/servicios#${layer.slug}`}
            class="chain-link"
            style="
              display:inline-flex; align-items:center; gap:0.375rem;
              font-size:0.8125rem; font-weight:600;
              color: var(--color-bie-accent);
              text-decoration:none;
              opacity:0;
              transition: opacity 0.2s, gap 0.2s;
            "
          >
            Ver productos
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div style="text-align:center; margin-top:2.5rem;" data-fade>
      <a href="/servicios" class="btn btn-outline" style="font-size:0.9375rem;">
        Explorar el catálogo completo — 14 productos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  @media (min-width: 600px) {
    .chain-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (min-width: 1024px) {
    .chain-grid { grid-template-columns: repeat(3, 1fr) !important; }
  }

  .chain-card:hover .chain-link { opacity: 1 !important; }
</style>
