---
import { valueLayers } from '../../data/services.ts';
import type { ValueLayer } from '../../types/index.ts';

const layerIcons: Record<string, string> = {
  identidad: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  presencia: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  datos: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
  automatizacion: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  inteligencia: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.14"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.14"/></svg>`,
  escala: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
};
---

<section
  id="value-chain"
  style="background: var(--color-bg-primary);"
  class="sec"
  aria-labelledby="value-chain-heading"
>
  <div class="ctn">

    <!-- Header -->
    <div class="vc-header" data-fade>
      <span class="tag">Cómo construimos tu ventaja</span>
      <h2 id="value-chain-heading" class="vc-h2">
        Seis capas. Tu empresa<br>entra donde está.
      </h2>
      <p class="vc-sub">
        No necesitas todo al mismo tiempo. Activamos las capas que tienen sentido para tu negocio ahora, en el orden correcto.
      </p>
    </div>

    <!-- Row list -->
    <div class="vc-rows" role="list">
      {valueLayers.map((layer, i) => (
        <div
          class="vc-row"
          role="listitem"
          data-fade
          data-delay={String(i * 55)}
        >
          <!-- Number -->
          <span class="vc-num" aria-hidden="true">{layer.number}</span>

          <!-- Name + icon -->
          <div class="vc-name-wrap">
            <span class="vc-icon" aria-hidden="true" set:html={layerIcons[layer.slug] ?? ''} />
            <p class="vc-name">{layer.name}</p>
          </div>

          <!-- Tagline + pills -->
          <div class="vc-main">
            <h3 class="vc-tagline">{layer.tagline}</h3>
            <div class="vc-pills">
              {layer.products.map(p => (
                <a href={`/servicios/${layer.slug}/${p.slug}`} class="vc-pill">{p.shortName}</a>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <a href={`/servicios#${layer.slug}`} class="vc-link" aria-label={`Ver productos de ${layer.name}`}>
            Ver productos
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div style="text-align:center; margin-top:3rem;" data-fade>
      <a href="/servicios" class="btn btn-outline" style="font-size:0.9375rem;">
        Catálogo completo — 36 productos
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .vc-header {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .vc-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin: 0.75rem 0 1rem;
  }

  .vc-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Rows */
  .vc-rows { display: flex; flex-direction: column; }

  .vc-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    grid-template-rows: auto auto;
    gap: 0.25rem 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
    transition: background 0.15s;
  }
  .vc-rows .vc-row:first-child { border-top: 1px solid var(--color-border); }

  .vc-num {
    grid-row: 1 / 3;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    padding-top: 0.25rem;
  }

  .vc-name-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .vc-icon {
    color: var(--color-bie-accent);
    flex-shrink: 0;
    opacity: 0.8;
  }

  .vc-name {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bie-accent);
    margin-bottom: 0;
  }

  .vc-main { min-width: 0; }

  .vc-tagline {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.35;
    margin-bottom: 0.75rem;
  }

  .vc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .vc-pill {
    display: inline-block;
    padding: 0.2rem 0.625rem;
    border-radius: 999px;
    background: var(--color-bg-secondary);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .vc-pill:hover {
    background: var(--color-bie-accent);
    color: white;
  }

  .vc-link {
    display: none;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-bie-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.15s;
    grid-column: 2;
    margin-top: 0.75rem;
  }
  .vc-row:hover .vc-link { display: inline-flex; }
  .vc-link:hover { gap: 0.625rem; }

  /* Desktop: 4-column row */
  @media (min-width: 768px) {
    .vc-row {
      grid-template-columns: 3rem 9.5rem 1fr auto;
      grid-template-rows: 1fr;
      gap: 0 2rem;
      align-items: center;
      padding: 1.5rem 0;
    }
    .vc-num { grid-row: 1; }
    .vc-name { grid-row: 1; padding-top: 0; }
    .vc-main { grid-row: 1; }
    .vc-link { grid-row: 1; grid-column: 4; margin-top: 0; opacity: 0; }
    .vc-row:hover .vc-link { opacity: 1; display: inline-flex; }
  }
</style>
