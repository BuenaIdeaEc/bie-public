<section
  id="value-chain"
  style="background: var(--color-bg-primary);"
  class="sec"
  aria-labelledby="value-chain-heading"
>
  <div class="ctn">

    <!-- Header -->
    <div class="vc-header" data-fade>
      <span class="tag">Cómo construimos tu ventaja</span>
      <h2 id="value-chain-heading" class="vc-h2">
        Seis capas. Tu empresa<br>entra donde está.
      </h2>
      <p class="vc-sub">
        No necesitas todo al mismo tiempo. Activamos las capas que tienen sentido para tu negocio ahora, en el orden correcto.
      </p>
    </div>

    <!-- Sticky scroll wrapper -->
    <div class="vc-wrap">

      <!-- Left: Row list -->
      <div class="vc-rows" role="list">
        {valueLayers.map((layer, i) => (
          <div
            class="vc-row"
            role="listitem"
            data-fade
            data-delay={String(i * 55)}
            data-slug={layer.slug}
          >
            <span class="vc-num" aria-hidden="true">{layer.number}</span>

            <div class="vc-name-wrap">
              <span class="vc-icon" aria-hidden="true" set:html={layerIcons[layer.slug] ?? ''} />
              <p class="vc-name">{layer.name}</p>
            </div>

            <div class="vc-main">
              <h3 class="vc-tagline">{layer.tagline}</h3>
              <div class="vc-pills">
                {layer.products.map(p => (
                  <a href={`/servicios/${layer.slug}/${p.slug}`} class="vc-pill">{p.shortName}</a>
                ))}
              </div>
              <!-- Mobile visual -->
              <div class="vc-mobile-visual" aria-hidden="true" set:html={layerVisuals[layer.slug] ?? ''} />
            </div>

            <a href={`/servicios#${layer.slug}`} class="vc-link" aria-label={`Ver productos de ${layer.name}`}>
              Ver productos
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>

      <!-- Right: Sticky visual panel (desktop) -->
      <div class="vc-sticky" aria-hidden="true" id="vc-sticky">
        {valueLayers.map((layer, i) => (
          <div
            class={`vc-vis${i === 0 ? ' active' : ''}`}
            data-slug={layer.slug}
            set:html={layerVisuals[layer.slug] ?? ''}
          />
        ))}
      </div>

    </div>

    <!-- Bottom CTA -->
    <div style="text-align:center; margin-top:3rem;" data-fade>
      <a href="/servicios" class="btn btn-outline" style="font-size:0.9375rem;">
        Catálogo completo — 36 productos
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .vc-header {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .vc-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin: 0.75rem 0 1rem;
  }

  .vc-sub {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Layout */
  .vc-wrap {
    display: grid;
    grid-template-columns: 1fr;
    position: relative;
  }

  @media (min-width: 1024px) {
    .vc-wrap {
      grid-template-columns: 1fr 360px;
      gap: 0 3rem;
      align-items: start;
    }
  }

  /* Rows */
  .vc-rows { display: flex; flex-direction: column; }

  .vc-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    grid-template-rows: auto auto;
    gap: 0.25rem 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
    transition: background 0.15s;
  }
  .vc-rows .vc-row:first-child { border-top: 1px solid var(--color-border); }

  .vc-num {
    grid-row: 1 / 3;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    padding-top: 0.25rem;
  }

  .vc-name-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .vc-icon {
    color: var(--color-bie-accent);
    flex-shrink: 0;
    opacity: 0.8;
  }

  .vc-name {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bie-accent);
    margin-bottom: 0;
  }

  .vc-main { min-width: 0; }

  .vc-tagline {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.35;
    margin-bottom: 0.75rem;
  }

  .vc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .vc-pill {
    display: inline-block;
    padding: 0.2rem 0.625rem;
    border-radius: 999px;
    background: var(--color-bg-secondary);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .vc-pill:hover {
    background: var(--color-bie-accent);
    color: white;
  }

  .vc-link {
    display: none;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-bie-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.15s;
    grid-column: 2;
    margin-top: 0.75rem;
  }
  .vc-row:hover .vc-link { display: inline-flex; }
  .vc-link:hover { gap: 0.625rem; }

  /* Mobile visual — below pills */
  .vc-mobile-visual {
    margin-top: 1rem;
    border-radius: 10px;
    overflow: hidden;
  }
  .vc-mobile-visual svg {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
  }

  /* Desktop: 4-column row */
  @media (min-width: 1024px) {
    .vc-row {
      grid-template-columns: 3rem 9.5rem 1fr auto;
      grid-template-rows: 1fr;
      gap: 0 2rem;
      align-items: center;
      padding: 1.5rem 0;
    }
    .vc-num { grid-row: 1; grid-column: 1; }
    .vc-name-wrap { grid-row: 1; grid-column: 2; align-items: center; }
    .vc-name { padding-top: 0; }
    .vc-main { grid-row: 1; grid-column: 3; }
    .vc-link { grid-row: 1; grid-column: 4; margin-top: 0; opacity: 0; }
    .vc-row:hover .vc-link { opacity: 1; display: inline-flex; }
    .vc-mobile-visual { display: none; }
  }

  /* Sticky visual panel */
  .vc-sticky {
    display: none;
  }

  @media (min-width: 1024px) {
    .vc-sticky {
      display: block;
      position: sticky;
      top: 90px;
      height: 310px;
      border-radius: 14px;
      overflow: hidden;
    }

    .vc-vis {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.45s ease;
    }
    .vc-vis svg {
      width: 100%;
      height: 100%;
      display: block;
    }
    .vc-vis.active { opacity: 1; }
  }
</style>

<script>
  const rows = document.querySelectorAll<HTMLElement>('.vc-row[data-slug]');
  const panel = document.getElementById('vc-sticky');

  if (rows.length && panel) {
    const visuals = panel.querySelectorAll<HTMLElement>('.vc-vis[data-slug]');
    let current = rows[0]?.dataset.slug ?? '';

    const setActive = (slug: string) => {
      if (slug === current) return;
      current = slug;
      visuals.forEach(v => v.classList.toggle('active', v.dataset.slug === slug));
    };

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const slug = (e.target as HTMLElement).dataset.slug ?? '';
          if (slug) setActive(slug);
        }
      });
    }, {
      threshold: 0.4,
      rootMargin: '-5% 0px -45% 0px',
    });

    rows.forEach(r => obs.observe(r));
  }
</script>
