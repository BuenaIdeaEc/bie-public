---
const stats = [
  { value: '92', label: 'Agentes IA\nen operación' },
  { value: '24/7', label: 'Sin pausas,\nsin excepciones' },
  { value: '6', label: 'Capas de valor\nen tu negocio' },
];
---

<section
  style="background: var(--color-bie-blue); position:relative; overflow:hidden;"
  class="sec"
  aria-labelledby="philosophy-heading"
>
  <!-- Subtle grid texture -->
  <div style="
    position:absolute; inset:0; pointer-events:none;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
  " aria-hidden="true"></div>

  <div class="ctn" style="position:relative; z-index:1;">

    <!-- Two-column: copy + dashboard -->
    <div class="ph-grid">

      <!-- Left: copy block -->
      <div class="ph-copy" data-fade>
        <span class="tag" style="color:var(--color-bie-gold);">Lo que operamos para ti</span>
        <h2 id="philosophy-heading" class="ph-h2">
          Tu empresa trabajando<br>mientras duermes.
        </h2>
        <div class="ph-body">
          <p>
            Este es el panel que BIE opera para sus clientes. 92 agentes activos, respondiendo leads en 28 segundos, calificando, registrando en CRM, generando reportes — sin intervención manual.
          </p>
          <p>
            Detrás de cada número hay criterio humano que diseñó el sistema. Delante, la IA que lo ejecuta sin parar.
          </p>
        </div>
        <a href="/sobre-bie" class="btn btn-outline-white">
          Conocer la filosofía BIE
        </a>
      </div>

      <!-- Right: dashboard mockup -->
      <div class="ph-visual" data-fade data-delay="120">
        <div class="ph-mockup-wrap">
          <img
            src="/images/home/dashboard-mockup.svg"
            alt="Panel de control BIE — 92 agentes IA en operación, leads en tiempo real"
            loading="lazy"
            width="900"
            height="560"
            style="width:100%; height:auto; display:block;"
          />
        </div>
      </div>

    </div>

    <!-- Bottom: large number strip -->
    <div class="ph-stats" data-fade data-delay="200" role="list">
      {stats.map((s, i) => (
        <div class="ph-stat" role="listitem">
          {i > 0 && <div class="ph-stat-divider" aria-hidden="true"></div>}
          <p class="ph-stat-val">{s.value}</p>
          <p class="ph-stat-label">{s.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .ph-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 1024px) {
    .ph-grid {
      grid-template-columns: 1fr 1.4fr;
      gap: 5rem;
      align-items: center;
    }
  }

  .ph-copy {
    /* no max-width here so it fills its grid column */
  }

  .ph-h2 {
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: white;
    margin: 0.75rem 0 1.5rem;
  }

  .ph-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .ph-body p {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.75;
  }

  /* Dashboard mockup wrapper */
  .ph-mockup-wrap {
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06);
    position: relative;
  }
  .ph-mockup-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.5rem;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);
    pointer-events: none;
  }

  /* Stats strip */
  .ph-stats {
    display: flex;
    align-items: flex-start;
    gap: 0;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.12);
    flex-wrap: wrap;
  }

  .ph-stat {
    display: flex;
    align-items: flex-start;
    gap: 0;
    flex: 1;
    min-width: 140px;
    position: relative;
  }

  .ph-stat-divider {
    width: 1px;
    height: 4rem;
    background: rgba(255,255,255,0.15);
    margin-right: 3rem;
    margin-top: 0.5rem;
    flex-shrink: 0;
  }

  .ph-stat-val {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.9;
    color: white;
    margin-right: 1rem;
  }

  .ph-stat-label {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
    white-space: pre-line;
    padding-top: 0.5rem;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .ph-stats { gap: 2rem; }
    .ph-stat { min-width: 100%; }
    .ph-stat-divider { display: none; }
    .ph-grid { margin-bottom: 3rem; }
  }
</style>
