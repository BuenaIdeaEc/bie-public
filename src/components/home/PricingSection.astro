---
import { pricingTiers } from '../../data/pricing.ts';
---

<section
  style="background: var(--color-bg-secondary);"
  class="sec"
  aria-labelledby="pricing-heading"
>
  <div class="ctn">

    <div style="text-align:center; max-width:600px; margin:0 auto 3.5rem;" data-fade>
      <span class="tag">Ecosistemas de Agentes IA</span>
      <h2 id="pricing-heading" class="t-h2" style="color:var(--color-text-primary); margin-bottom:1rem;">
        Elige el ecosistema que tu empresa necesita
      </h2>
      <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.7;">
        No es un chatbot. Es un equipo de agentes configurado, entrenado y operado por BIE para tu negocio.
      </p>
    </div>

    <!-- Pricing grid -->
    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
      max-width: 1000px;
      margin: 0 auto;
    " class="pricing-grid">
      {pricingTiers.map((tier, i) => (
        <article
          style={`
            border-radius: 1rem;
            padding: 2rem 1.75rem;
            display: flex;
            flex-direction: column;
            position: relative;
            ${tier.featured
              ? `background: var(--color-bie-blue); box-shadow: 0 16px 48px rgba(27,58,92,0.28);`
              : `background: var(--color-bg-primary); border: 1px solid var(--color-border); box-shadow: var(--shadow-card);`
            }
          `}
          data-fade
          data-delay={String(i * 100)}
        >
          <!-- Popular badge -->
          {tier.badge && (
            <div style={`
              position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
              padding: 0.25rem 0.875rem;
              border-radius: 999px;
              font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.06em;
              white-space: nowrap;
              ${tier.featured
                ? 'background: var(--color-bie-gold); color: white;'
                : 'background: var(--color-bie-blue); color: white;'
              }
            `}>
              {tier.badge}
            </div>
          )}

          <!-- Tier name -->
          <p style={`font-size:0.6875rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:0.375rem; margin-top:${tier.badge ? '0.5rem' : '0'}; color:${tier.featured ? 'rgba(255,255,255,0.5)' : 'var(--color-text-tertiary)'};`}>
            {tier.name}
          </p>

          <!-- Price -->
          <div style="display:flex; align-items:baseline; gap:0.25rem; margin-bottom:0.375rem;">
            <span style={`font-size:2rem; font-weight:700; letter-spacing:-0.03em; line-height:1; color:${tier.featured ? 'white' : 'var(--color-text-primary)'};`}>
              {tier.price}
            </span>
            <span style={`font-size:0.875rem; color:${tier.featured ? 'rgba(255,255,255,0.5)' : 'var(--color-text-tertiary)'};`}>
              {tier.priceNote}
            </span>
          </div>

          <p style={`font-size:0.875rem; line-height:1.6; margin-bottom:1.5rem; color:${tier.featured ? 'rgba(255,255,255,0.65)' : 'var(--color-text-secondary)'};`}>
            {tier.description}
          </p>

          <!-- Feature list -->
          <ul style="list-style:none; padding:0; margin:0 0 1.75rem; display:flex; flex-direction:column; gap:0.625rem; flex:1;" role="list">
            {tier.features.map(f => (
              <li style={`display:flex; align-items:flex-start; gap:0.5rem; font-size:0.875rem; color:${tier.featured ? 'rgba(255,255,255,0.75)' : 'var(--color-text-secondary)'};`}>
                <svg style={`flex-shrink:0; margin-top:1px; color:${tier.featured ? 'var(--color-bie-gold)' : 'var(--color-bie-accent)'};`} width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={tier.cta.href}
            class={tier.featured ? 'btn btn-white' : 'btn btn-outline'}
            style="width:100%; text-align:center; font-size:0.9375rem;"
          >
            {tier.cta.label}
          </a>
        </article>
      ))}
    </div>

    <!-- Add-ons note -->
    <p style="text-align:center; margin-top:2rem; font-size:0.8125rem; color:var(--color-text-tertiary);" data-fade>
      Add-ons disponibles: Agente custom · Integración extra · Auditoría IA · Migración de datos · White-label
    </p>

  </div>
</section>

<style>
  @media (min-width: 768px) {
    .pricing-grid { grid-template-columns: repeat(3, 1fr) !important; align-items: start !important; }
  }
</style>
