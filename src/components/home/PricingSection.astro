---
const tiers = [
  {
    name: 'Arranque',
    description: 'Para negocios que dan su primer paso en automatización real.',
    includes: [
      '3–5 agentes IA configurados',
      'WhatsApp Business integrado',
      'Automatización de ventas básica',
      'Dashboard de seguimiento',
    ],
    wa: 'Hola%2C+me+interesa+el+ecosistema+Arranque+de+BIE+para+mi+empresa.+%C2%BFPueden+darme+m%C3%A1s+informaci%C3%B3n%3F',
    featured: false,
    badge: null,
  },
  {
    name: 'Profesional',
    description: 'Para PyMEs con procesos complejos que exigen resultados medibles.',
    includes: [
      '8–15 agentes IA especializados',
      'Integraciones múltiples (CRM, ERP, WA)',
      'Ops + ventas + marketing + finanzas',
      'Reportes semanales y soporte 24/7',
    ],
    wa: 'Hola%2C+me+interesa+el+ecosistema+Profesional+de+BIE.+%C2%BFPueden+enviarme+una+propuesta%3F',
    featured: true,
    badge: 'Más elegido',
  },
  {
    name: 'Empresa',
    description: 'Para organizaciones en transformación digital de alta demanda.',
    includes: [
      '20–40+ agentes con orquestador dedicado',
      'Integraciones enterprise (SAP, Salesforce)',
      'SLA garantizado + Gerente de cuenta',
      'Escala sin límite + White-label opcional',
    ],
    wa: 'Hola%2C+me+interesa+el+ecosistema+Empresa+de+BIE.+Tenemos+una+operaci%C3%B3n+grande.+%C2%BFPodemos+hablar%3F',
    featured: false,
    badge: null,
  },
];
---

<section
  id="ecosistemas"
  style="background: var(--color-bg-secondary);"
  class="sec"
  aria-labelledby="pricing-heading"
>
  <div class="ctn">

    <div style="text-align:center; max-width:600px; margin:0 auto 3.5rem;" data-fade>
      <span class="tag">Ecosistemas de Agentes IA</span>
      <h2 id="pricing-heading" class="t-h2" style="color:var(--color-text-primary); margin-bottom:1rem;">
        No vendemos software.<br>Operamos inteligencia.
      </h2>
      <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.7;">
        Un ecosistema de agentes IA no es un chatbot. Es un equipo digital
        configurado, entrenado y operado por BIE para tu negocio específico.
      </p>
    </div>

    <!-- Tier cards (no prices) -->
    <div style="
      display:grid; grid-template-columns:1fr;
      gap:1.25rem; max-width:1000px; margin:0 auto 3rem;
    " class="pricing-grid">
      {tiers.map((tier, i) => (
        <article
          style={`
            border-radius:1rem; padding:2rem 1.75rem;
            display:flex; flex-direction:column; position:relative;
            ${tier.featured
              ? 'background:var(--color-bie-blue); box-shadow:0 12px 40px rgba(27,58,92,0.2);'
              : 'background:var(--color-bg-primary); border:1px solid var(--color-border);'
            }
          `}
          data-fade
          data-delay={String(i * 100)}
        >
          {tier.badge && (
            <div style={`
              position:absolute; top:-13px; left:50%; transform:translateX(-50%);
              padding:0.2rem 0.875rem; border-radius:999px;
              font-size:0.6875rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase;
              white-space:nowrap; background:var(--color-bie-gold); color:white;
            `}>
              {tier.badge}
            </div>
          )}

          <p style={`
            font-size:0.6875rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase;
            margin-bottom:0.5rem; margin-top:${tier.badge ? '0.5rem' : '0'};
            color:${tier.featured ? 'rgba(255,255,255,0.45)' : 'var(--color-text-tertiary)'};
          `}>
            {tier.name}
          </p>

          <p style={`
            font-size:0.9375rem; line-height:1.6; margin-bottom:1.5rem;
            color:${tier.featured ? 'rgba(255,255,255,0.7)' : 'var(--color-text-secondary)'};
          `}>
            {tier.description}
          </p>

          <ul style="list-style:none; padding:0; margin:0 0 2rem; display:flex; flex-direction:column; gap:0.625rem; flex:1;" role="list">
            {tier.includes.map(f => (
              <li style={`
                display:flex; align-items:flex-start; gap:0.5rem; font-size:0.875rem;
                color:${tier.featured ? 'rgba(255,255,255,0.7)' : 'var(--color-text-secondary)'};
              `}>
                <svg style={`flex-shrink:0; margin-top:1px; color:${tier.featured ? 'var(--color-bie-gold)' : 'var(--color-bie-accent)'};`}
                  width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={`https://wa.me/593998825303?text=${tier.wa}`}
            target="_blank"
            rel="noopener noreferrer"
            class={tier.featured ? 'btn btn-white' : 'btn btn-outline'}
            style="width:100%; text-align:center; font-size:0.9375rem;"
          >
            Consultar por {tier.name}
          </a>
        </article>
      ))}
    </div>

    <!-- Cost block -->
    <div
      style="
        max-width:640px; margin:0 auto; text-align:center;
        padding:2.5rem; border-radius:1.25rem;
        background:var(--color-bg-primary); border:1px solid var(--color-border);
      "
      data-fade
    >
      <h3 style="font-size:1.25rem; font-weight:600; color:var(--color-text-primary); margin-bottom:0.75rem; letter-spacing:-0.015em;">
        ¿Cuánto cuesta exactamente?
      </h3>
      <p style="font-size:0.9375rem; color:var(--color-text-secondary); line-height:1.7; margin-bottom:1.75rem;">
        El costo depende de tu operación, no de un menú estándar.
        Cuéntanos en 5 minutos qué necesitas y te enviamos
        una propuesta real en menos de 24 horas.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:0.75rem; justify-content:center;">
        <a
          href="https://wa.me/593998825303?text=Hola%2C+quiero+saber+el+costo+de+un+ecosistema+de+agentes+IA+para+mi+empresa.+%C2%BFPueden+enviarme+una+propuesta%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          Solicitar propuesta personalizada
        </a>
        <a
          href="mailto:hola@bie.ec?subject=Propuesta%20Ecosistema%20de%20Agentes%20IA&body=Hola%20BIE%2C%0A%0AMe%20interesa%20un%20ecosistema%20de%20agentes%20IA.%20Mi%20empresa%20se%20llama%20%5Bnombre%5D%20y%20el%20proceso%20que%20m%C3%A1s%20tiempo%20me%20toma%20es%20%5Bproceso%5D.%0A%0AGracias."
          class="btn btn-outline"
        >
          hola@bie.ec
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  @media (min-width: 768px) {
    .pricing-grid { grid-template-columns: repeat(3, 1fr) !important; align-items: start !important; }
  }
</style>
