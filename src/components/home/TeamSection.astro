---
import { teamMembers } from '../../data/team.ts';

const colors = ['#1B3A5C', '#2E75B6', '#C4972A', '#4B5563'];
---

<section
  style="background: var(--color-bg-primary);"
  class="sec"
  aria-labelledby="team-heading"
>
  <div class="ctn">
    <div class="tm-layout">

      <!-- Left: sticky heading -->
      <div class="tm-left" data-fade>
        <span class="tag">El equipo</span>
        <h2 id="team-heading" class="tm-h2">
          Las personas<br>detrás de los<br>agentes.
        </h2>
        <p class="tm-sub">
          El resto del equipo son 92 agentes IA — cada uno con nombre,
          función y sistema documentado.
        </p>
      </div>

      <!-- Right: member rows -->
      <div class="tm-rows" role="list">
        {teamMembers.map((m, i) => (
          <div
            class="tm-row"
            role="listitem"
            data-fade
            data-delay={String(i * 80)}
          >
            <!-- Avatar -->
            <div
              class="tm-avatar"
              style={`background:${colors[i % colors.length]};`}
              aria-hidden="true"
            >
              {m.initials}
            </div>

            <!-- Info -->
            <div class="tm-info">
              <h3 class="tm-name">{m.name}</h3>
              <p class="tm-role">{m.role}</p>
              <p class="tm-bio">{m.bio}</p>
              {m.linkedin && (
                <a
                  href={m.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="tm-li"
                  aria-label={`LinkedIn de ${m.name}`}
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .tm-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .tm-layout {
      grid-template-columns: 34% 1fr;
      gap: 6rem;
      align-items: start;
    }
    .tm-left { position: sticky; top: 100px; }
  }

  .tm-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin: 0.75rem 0 1rem;
  }

  .tm-sub {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Rows */
  .tm-rows { display: flex; flex-direction: column; }

  .tm-row {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .tm-rows .tm-row:first-child { border-top: 1px solid var(--color-border); }

  .tm-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .tm-info { flex: 1; min-width: 0; }

  .tm-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 0.1rem;
  }

  .tm-role {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-bie-accent);
    margin-bottom: 0.5rem;
    letter-spacing: 0.005em;
  }

  .tm-bio {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .tm-li {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.625rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #0A66C2;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .tm-li:hover { opacity: 0.75; }
</style>
