---
import { teamMembers } from '../../data/team.ts';

const avatarColors = ['#1B3A5C', '#2E75B6'];
---

<section
  style="background: var(--color-bg-secondary);"
  class="sec"
  aria-labelledby="team-heading"
>
  <div class="ctn">

    <div style="text-align:center; max-width:560px; margin:0 auto 3rem;" data-fade>
      <span class="tag">El equipo</span>
      <h2 id="team-heading" class="t-h2" style="color:var(--color-text-primary); margin-bottom:0.75rem;">
        Quiénes mantenemos el 1% humano
      </h2>
      <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.7;">
        El resto del equipo son 92 agentes IA. Cada uno con nombre, función y
        prompt del sistema documentado.
      </p>
    </div>

    <!-- Team cards -->
    <div style="
      display:grid; grid-template-columns:1fr;
      gap:1.25rem; max-width:720px; margin:0 auto 3rem;
    " class="team-grid">
      {teamMembers.map((member, i) => (
        <article
          class="card"
          style="padding:1.75rem; display:flex; gap:1.25rem; align-items:flex-start;"
          data-fade
          data-delay={String(i * 100)}
        >
          <!-- Avatar -->
          <div style={`
            width:64px; height:64px; border-radius:50%;
            background: ${avatarColors[i]};
            display:flex; align-items:center; justify-content:center;
            font-size:1rem; font-weight:700; color:white;
            flex-shrink:0; letter-spacing:0.04em;
          `}>
            {member.initials}
          </div>

          <div style="flex:1; min-width:0;">
            <h3 style="font-size:1.0625rem; font-weight:600; color:var(--color-text-primary); margin-bottom:0.2rem; letter-spacing:-0.01em;">
              {member.name}
            </h3>
            <p style="font-size:0.8125rem; font-weight:500; color:var(--color-bie-accent); margin-bottom:0.625rem;">
              {member.role}
            </p>
            <p style="font-size:0.9rem; color:var(--color-text-secondary); line-height:1.6;">
              {member.bio}
            </p>
            {member.linkedin && (
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                style="
                  display:inline-flex; align-items:center; gap:0.375rem;
                  margin-top:0.75rem;
                  font-size:0.8125rem; font-weight:500;
                  color:#0A66C2; text-decoration:none;
                  transition: opacity 0.15s;
                "
                class="li-link"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                Ver perfil en LinkedIn
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- AI agents banner -->
    <div style="
      max-width:720px; margin:0 auto;
      background: var(--color-bie-blue);
      border-radius:1rem;
      padding:1.75rem;
      display:flex; flex-wrap:wrap;
      align-items:center; gap:1.25rem;
    " data-fade>
      <div style="
        width:52px; height:52px; border-radius:50%;
        background:rgba(255,255,255,0.12);
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0;
      ">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>
      </div>
      <div style="flex:1;">
        <p style="font-size:1rem; font-weight:600; color:white; margin-bottom:0.25rem;">
          + 92 agentes IA
        </p>
        <p style="font-size:0.875rem; color:rgba(255,255,255,0.6); line-height:1.5;">
          Cada agente tiene nombre, función y prompt del sistema documentado.
          Los conoces cuando trabajamos contigo.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  @media (min-width: 640px) {
    .team-grid { grid-template-columns: repeat(2, 1fr) !important; max-width:100% !important; }
  }
  .li-link:hover { opacity: 0.75; }
</style>
