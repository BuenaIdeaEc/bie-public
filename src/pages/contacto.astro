---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto — Solicita tu diagnóstico gratuito | BIE Ecuador"
  description="Solicita un diagnóstico gratuito de 30 minutos. Sin costo, sin presión. Te decimos exactamente qué necesitas y qué inversión implica."
>
  <!-- Hero -->
  <section style="background:var(--color-bg-primary); padding-top:5rem; padding-bottom:3rem;" aria-labelledby="contact-heading">
    <div class="ctn" style="max-width:680px;" data-fade>
      <span class="tag">Contacto</span>
      <h1 id="contact-heading" style="font-size:clamp(2rem,5vw,3.5rem); font-weight:700; letter-spacing:-0.035em; line-height:1.05; color:var(--color-text-primary); margin:0.75rem 0 1.25rem;">
        Un diagnóstico de 30 minutos que lo cambia todo.
      </h1>
      <p style="font-size:1.125rem; color:var(--color-text-secondary); line-height:1.7;">
        Sin costo. Sin compromiso. Te decimos exactamente qué capa de nuestra cadena de valor necesitas, qué inversión implica y qué retorno puedes esperar para tu empresa específica.
      </p>
    </div>
  </section>

  <!-- Main -->
  <section style="padding-bottom:5rem;" aria-label="Formulario de contacto y opciones de comunicación">
    <div class="ctn">
      <div class="ct-grid">

        <!-- Left: options -->
        <div data-fade>
          <h2 style="font-size:1.125rem; font-weight:600; color:var(--color-text-primary); margin-bottom:1.75rem; letter-spacing:-0.01em;">
            Cómo prefiere contactarnos
          </h2>

          <div style="display:flex; flex-direction:column; gap:0.875rem;">
            <a
              href="https://wa.me/593998825303?text=Hola%2C+quiero+solicitar+un+diagn%C3%B3stico+gratuito+de+BIE."
              target="_blank" rel="noopener noreferrer"
              class="ct-option"
            >
              <div class="ct-option-icon" style="background:#25D366;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm.029 18.88a7.945 7.945 0 01-3.793-.965l-4.205 1.104 1.126-4.111a7.955 7.955 0 01-1.063-3.969C4.094 7.067 7.748 3.413 12.029 3.413c4.281 0 7.935 3.654 7.935 7.935-.001 4.282-3.654 7.532-7.935 7.532z"/></svg>
              </div>
              <div>
                <p class="ct-option-title">WhatsApp</p>
                <p class="ct-option-sub">+593 99 882 5303 · Respuesta en &lt; 1 hora</p>
              </div>
            </a>

            <a href="mailto:hola@bie.ec" class="ct-option">
              <div class="ct-option-icon" style="background:var(--color-bie-accent);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="ct-option-title">Email</p>
                <p class="ct-option-sub">hola@bie.ec · Respuesta en &lt; 24 horas</p>
              </div>
            </a>
          </div>

          <!-- Trust signals -->
          <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid var(--color-border);">
            <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-text-tertiary); margin-bottom:1.25rem;">En el diagnóstico cubrimos</p>
            <ul class="check-list">
              <li>Qué capa del modelo BIE tiene más impacto en tu empresa hoy</li>
              <li>Estimación de inversión y retorno esperado</li>
              <li>Ejemplos de empresas similares a la tuya</li>
              <li>Próximos pasos concretos si decides avanzar</li>
            </ul>
          </div>
        </div>

        <!-- Right: form -->
        <div data-fade data-delay="120">
          <div class="ct-form-wrap">
            <h2 style="font-size:1.125rem; font-weight:600; color:var(--color-text-primary); margin-bottom:0.375rem; letter-spacing:-0.01em;">
              Solicitar diagnóstico gratuito
            </h2>
            <p style="font-size:0.875rem; color:var(--color-text-secondary); margin-bottom:1.75rem;">
              Respuesta en menos de 24 horas hábiles.
            </p>

            <form
              id="ct-form"
              name="diagnostico"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              novalidate
              style="display:flex; flex-direction:column; gap:1rem;"
            >
              <input type="hidden" name="form-name" value="diagnostico" />
              <input type="text" name="bot-field" style="display:none;" tabindex="-1" aria-hidden="true" />

              <div class="ct-row">
                <div>
                  <label for="ct-name" class="f-label">Nombre *</label>
                  <input type="text" id="ct-name" name="name" required autocomplete="name" placeholder="Ana Torres" class="f-input" />
                </div>
                <div>
                  <label for="ct-company" class="f-label">Empresa *</label>
                  <input type="text" id="ct-company" name="company" required autocomplete="organization" placeholder="Mi Empresa S.A." class="f-input" />
                </div>
              </div>

              <div>
                <label for="ct-email" class="f-label">Correo electrónico *</label>
                <input type="email" id="ct-email" name="email" required autocomplete="email" placeholder="ana@empresa.com" class="f-input" />
              </div>

              <div>
                <label for="ct-phone" class="f-label">WhatsApp / Teléfono</label>
                <input type="tel" id="ct-phone" name="phone" autocomplete="tel" placeholder="+593 99 000 0000" class="f-input" />
              </div>

              <div>
                <label for="ct-interest" class="f-label">¿Qué te interesa?</label>
                <select id="ct-interest" name="service" class="f-input" style="cursor:pointer;">
                  <option value="">Seleccionar...</option>
                  <option value="automatizacion">Automatización de procesos</option>
                  <option value="agentes-ia">Ecosistema de Agentes IA</option>
                  <option value="datos">Datos e infraestructura</option>
                  <option value="identidad">Identidad y marca</option>
                  <option value="presencia">Presencia digital</option>
                  <option value="escala">Escala y expansión</option>
                  <option value="diagnostico">Diagnóstico integral</option>
                </select>
              </div>

              <div>
                <label for="ct-message" class="f-label">Cuéntanos brevemente tu empresa</label>
                <textarea id="ct-message" name="message" rows="3" placeholder="A qué se dedica tu empresa, cuántas personas tiene, qué proceso quisieras mejorar..." class="f-input" style="resize:vertical;"></textarea>
              </div>

              <button type="submit" id="ct-submit" class="btn btn-primary" style="width:100%; font-size:0.9375rem;">
                Solicitar diagnóstico gratuito
              </button>

              <p style="font-size:0.75rem; color:var(--color-text-tertiary); text-align:center;">
                Sin spam. Tus datos se usan solo para coordinar la llamada.
              </p>

              <div id="ct-success" style="display:none; padding:1.25rem; border-radius:0.5rem; background:rgba(16,185,129,0.08); border:1px solid rgba(16,185,129,0.25); text-align:center;" role="alert" aria-live="polite">
                <svg style="margin:0 auto 0.5rem; display:block; color:#10B981;" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                <p style="font-size:0.9375rem; font-weight:600; color:var(--color-text-primary); margin-bottom:0.25rem;">¡Recibido!</p>
                <p style="font-size:0.875rem; color:var(--color-text-secondary);">Te contactamos en menos de 24 horas hábiles.</p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ct-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .ct-grid { grid-template-columns: 1fr 1.1fr; gap: 6rem; }
  }

  .ct-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s;
  }
  .ct-option:hover { border-color: var(--color-bie-accent); background: var(--color-bg-secondary); }

  .ct-option-icon {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .ct-option-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.125rem;
  }

  .ct-option-sub {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .ct-form-wrap {
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-form);
  }

  .ct-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  @media (max-width: 480px) {
    .ct-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('ct-form') as HTMLFormElement | null;
  const success = document.getElementById('ct-success');
  const submit = document.getElementById('ct-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submit || !success) return;
    submit.textContent = 'Enviando...';
    submit.setAttribute('disabled', 'true');
    try {
      const data = new FormData(form);
      const body = new URLSearchParams();
      data.forEach((v, k) => body.append(k, String(v)));
      await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() });
      form.style.display = 'none';
      success.style.display = 'block';
    } catch {
      submit.textContent = 'Error. Escríbenos por WhatsApp.';
      submit.removeAttribute('disabled');
    }
  });
</script>
