---
import BaseLayout from '../layouts/BaseLayout.astro';
import { teamMembers } from '../data/team.ts';

const colors = ['#1B3A5C', '#2E75B6', '#C4972A', '#4B5563'];

const timeline = [
  { year: '2022', event: 'BIE nace en Guayaquil con la misión de hacer accesible la automatización empresarial para PyMEs ecuatorianas.' },
  { year: '2023', event: 'Primeros ecosistemas de agentes IA en producción. 40 agentes activos. Primer cliente en sector inmobiliario.' },
  { year: '2024', event: '92 agentes activos en 3 industrias. Expansión al sector óptico y retail. Desarrollo del Programa Satélites.' },
  { year: '2025', event: 'Plataforma multi-tenant lista. Expansión a Colombia y Perú en desarrollo. 6 capas de valor completamente documentadas.' },
];

const values = [
  { title: 'Operamos, no entregamos', body: 'Cualquier agencia puede construir software y desaparecer. BIE opera lo que construye. Si no funciona, es nuestro problema.' },
  { title: 'Resultados o no hay negocio', body: 'Cada proyecto tiene métricas de éxito definidas antes de empezar. Si no las alcanzamos, lo decimos antes de cobrar.' },
  { title: 'Tecnología de primer nivel, explicada en simple', body: 'GPT-4, Claude, arquitecturas multi-agente — pero explicados en términos de tu negocio, no de papers académicos.' },
  { title: 'El criterio humano no se automatiza', body: 'La IA ejecuta. Las personas estrategizan. Esa combinación es lo que construimos para nuestros clientes y para nosotros mismos.' },
];
---

<BaseLayout
  title="Sobre BIE — Quiénes somos y por qué lo hacemos | Ecuador"
  description="BIE construye y opera ecosistemas de agentes IA para PyMEs en Ecuador. Conoce nuestra misión, el equipo y la filosofía detrás de nuestra forma de trabajar."
>
  <!-- Hero -->
  <section style="background:#000000; min-height:60vh; display:flex; align-items:center; position:relative; overflow:hidden;" aria-labelledby="sb-heading">
    <div aria-hidden="true" style="position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px); background-size:40px 40px;"></div>
    <div aria-hidden="true" style="position:absolute; inset:0; background:radial-gradient(ellipse 80% 60% at 50% 50%,transparent 40%,rgba(0,0,0,0.6) 100%);"></div>
    <div aria-hidden="true" style="position:absolute; bottom:0; left:0; right:0; height:120px; background:linear-gradient(to bottom,transparent,#fff);"></div>
    <div class="ctn" style="position:relative; z-index:1; padding-top:8rem; padding-bottom:8rem; max-width:820px;" data-fade>
      <span class="tag" style="color:rgba(196,151,42,0.8);">Sobre BIE</span>
      <h1 id="sb-heading" style="font-size:clamp(2.5rem,7vw,5.5rem); font-weight:700; letter-spacing:-0.04em; line-height:0.95; color:white; margin:1rem 0 1.5rem;">
        Construimos la empresa que opera mientras duermes.
      </h1>
      <p style="font-size:1.125rem; color:rgba(255,255,255,0.5); line-height:1.7; max-width:52ch;">
        No somos una consultora. No somos una agencia. Somos el equipo que diseña, construye y opera el sistema operativo tecnológico de tu empresa.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="sec" style="background:var(--color-bg-primary);" aria-labelledby="mission-heading">
    <div class="ctn">
      <div style="display:grid; grid-template-columns:1fr; gap:4rem;" class="sb-2col">
        <div data-fade>
          <span class="tag">Misión</span>
          <h2 id="mission-heading" style="font-size:clamp(1.75rem,4vw,2.75rem); font-weight:700; letter-spacing:-0.03em; line-height:1.08; color:var(--color-text-primary); margin:0.75rem 0 1.25rem;">
            Hacer que la IA no sea solo para las grandes empresas.
          </h2>
          <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.75; margin-bottom:1.25rem;">
            Las empresas Fortune 500 llevan años usando inteligencia artificial para optimizar operaciones, ventas y logística. Las PyMEs ecuatorianas no tienen ese presupuesto ni ese equipo técnico interno.
          </p>
          <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.75;">
            BIE cierra esa brecha. Construimos los mismos sistemas — la misma calidad de IA, la misma arquitectura, los mismos resultados — adaptados al tamaño, presupuesto y realidad de tu empresa.
          </p>
        </div>
        <div data-fade data-delay="120">
          <div style="border-top:1px solid var(--color-border); padding-top:2.5rem;">
            <p style="font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.05em; line-height:0.85; color:var(--color-bie-blue); margin-bottom:0.5rem;">92</p>
            <p style="font-size:0.875rem; color:var(--color-text-secondary);">Agentes IA activos</p>
          </div>
          <div style="border-top:1px solid var(--color-border); padding-top:2.5rem; margin-top:2.5rem;">
            <p style="font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.05em; line-height:0.85; color:var(--color-bie-blue); margin-bottom:0.5rem;">3</p>
            <p style="font-size:0.875rem; color:var(--color-text-secondary);">Industrias en operación</p>
          </div>
          <div style="border-top:1px solid var(--color-border); padding-top:2.5rem; margin-top:2.5rem;">
            <p style="font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.05em; line-height:0.85; color:var(--color-bie-blue); margin-bottom:0.5rem;">6</p>
            <p style="font-size:0.875rem; color:var(--color-text-secondary);">Capas del modelo BIE</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="sec" style="background:var(--color-bg-secondary);" aria-labelledby="values-heading">
    <div class="ctn">
      <div style="max-width:560px; margin-bottom:3.5rem;" data-fade>
        <span class="tag">Lo que creemos</span>
        <h2 id="values-heading" style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:700; letter-spacing:-0.025em; color:var(--color-text-primary); margin-top:0.75rem;">
          Los principios que guían cada decisión.
        </h2>
      </div>
      <div class="sb-values-grid">
        {values.map((v, i) => (
          <div class="sb-value" data-fade data-delay={String(i * 80)}>
            <h3 class="sb-value-h">{v.title}</h3>
            <p class="sb-value-p">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="sec" style="background:var(--color-bg-primary);" aria-labelledby="timeline-heading">
    <div class="ctn">
      <div style="max-width:560px; margin-bottom:3.5rem;" data-fade>
        <span class="tag">Historia</span>
        <h2 id="timeline-heading" style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:700; letter-spacing:-0.025em; color:var(--color-text-primary); margin-top:0.75rem;">
          Cómo llegamos hasta aquí.
        </h2>
      </div>
      <div class="sb-timeline">
        {timeline.map((t, i) => (
          <div class="sb-tl-item" data-fade data-delay={String(i * 80)}>
            <div class="sb-tl-year">{t.year}</div>
            <div class="sb-tl-bar" aria-hidden="true"></div>
            <p class="sb-tl-event">{t.event}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="sec" style="background:var(--color-bg-secondary);" aria-labelledby="team-sb-heading">
    <div class="ctn">
      <div style="max-width:560px; margin-bottom:3.5rem;" data-fade>
        <span class="tag">El equipo humano</span>
        <h2 id="team-sb-heading" style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:700; letter-spacing:-0.025em; color:var(--color-text-primary); margin-top:0.75rem;">
          Las personas detrás de los agentes.
        </h2>
        <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.7; margin-top:0.75rem;">
          El resto del equipo son 92 agentes IA con nombre, función y sistema documentado.
        </p>
      </div>
      <div class="sb-team-grid">
        {teamMembers.map((m, i) => (
          <div class="sb-team-card" data-fade data-delay={String(i * 80)}>
            <div class="sb-team-avatar" style={`background:${colors[i % colors.length]};`}>
              {m.initials}
            </div>
            <div>
              <h3 class="sb-team-name">{m.name}</h3>
              <p class="sb-team-role">{m.role}</p>
              <p class="sb-team-bio">{m.bio}</p>
              {m.linkedin && (
                <a href={m.linkedin} target="_blank" rel="noopener noreferrer" class="sb-team-li">
                  LinkedIn →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--color-bie-blue); padding:5rem 0;" aria-labelledby="sb-cta-heading">
    <div class="ctn" style="max-width:600px; margin:0 auto; text-align:center;">
      <h2 id="sb-cta-heading" style="font-size:clamp(1.75rem,4vw,2.75rem); font-weight:700; letter-spacing:-0.03em; color:white; margin-bottom:1.25rem;" data-fade>
        ¿Te interesa trabajar con BIE?
      </h2>
      <p style="font-size:1.0625rem; color:rgba(255,255,255,0.6); margin-bottom:2rem;" data-fade data-delay="80">
        Solicita un diagnóstico gratuito de 30 minutos y te decimos exactamente cómo podemos ayudarte.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:0.75rem; justify-content:center;" data-fade data-delay="140">
        <a href="/#contacto" class="btn btn-white">Solicitar diagnóstico</a>
        <a href="/servicios" class="btn btn-outline-white">Ver catálogo</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (min-width: 1024px) {
    .sb-2col { grid-template-columns: 1fr 1fr !important; align-items: start; }
  }

  .sb-values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .sb-value {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .sb-values-grid .sb-value:first-child { border-top: 1px solid var(--color-border); }

  .sb-value-h {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }
  .sb-value-p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .sb-values-grid { grid-template-columns: repeat(2, 1fr); gap: 0 4rem; }
    .sb-value { border-right: none; }
  }

  .sb-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sb-tl-item {
    display: grid;
    grid-template-columns: 4rem auto 1fr;
    gap: 0 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }
  .sb-timeline .sb-tl-item:first-child { border-top: 1px solid var(--color-border); }

  .sb-tl-year {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-bie-accent);
    padding-top: 0.125rem;
  }

  .sb-tl-bar {
    width: 1px;
    background: var(--color-border);
    align-self: stretch;
    margin: 0.25rem 0;
  }

  .sb-tl-event {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .sb-team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .sb-team-card {
    display: flex;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: flex-start;
  }
  .sb-team-grid .sb-team-card:first-child { border-top: 1px solid var(--color-border); }

  .sb-team-avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700; color: white;
    flex-shrink: 0;
  }

  .sb-team-name {
    font-size: 1rem; font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.125rem;
  }
  .sb-team-role {
    font-size: 0.8125rem; font-weight: 500;
    color: var(--color-bie-accent);
    margin-bottom: 0.5rem;
  }
  .sb-team-bio {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }
  .sb-team-li {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #0A66C2;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .sb-team-grid { grid-template-columns: repeat(2, 1fr); gap: 0 4rem; }
  }
</style>
