---
import BaseLayout from '../layouts/BaseLayout.astro';

const benefits = [
  { title: 'Tecnología de primer nivel, tu marca', body: 'Accedes a toda la infraestructura de IA de BIE — agentes, base de conocimiento, flujos de automatización — y la ofreces bajo tu propia marca a tus clientes.' },
  { title: 'Ingresos recurrentes sin inversión técnica', body: 'No necesitas un equipo técnico interno ni mantener servidores. BIE opera la infraestructura. Tú vendes y cobras a tus clientes.' },
  { title: 'Soporte técnico BIE incluido', body: 'Cada satélite tiene acceso a soporte técnico prioritario y actualizaciones automáticas de los sistemas. Si algo falla, es nuestro problema, no el tuyo.' },
  { title: 'Capacitación y onboarding completo', body: 'Entrenamos a tu equipo para vender e implementar soluciones de IA. No necesitas saber programación para ser un satélite BIE.' },
];

const fits = [
  'Consultoras de negocio y management',
  'Agencias de marketing digital',
  'Estudios de abogados y contadores',
  'Distribuidores de software empresarial',
  'Coaches y consultores de transformación',
  'Empresas de capacitación corporativa',
];

const steps = [
  { num: '01', title: 'Aplicación', body: 'Completa el formulario de interés. Evaluamos el alineamiento estratégico en 48 horas.' },
  { num: '02', title: 'Diagnóstico conjunto', body: 'Una llamada de 60 minutos para entender tu cartera de clientes y definir el alcance de la alianza.' },
  { num: '03', title: 'Acuerdo y configuración', body: 'Firmamos el acuerdo de satélite. Configuramos tu acceso a la infraestructura BIE con tu branding.' },
  { num: '04', title: 'Capacitación del equipo', body: 'Entrenamos a tu equipo en 2 semanas. Incluye ventas, implementación y soporte básico.' },
  { num: '05', title: 'Primer cliente conjunto', body: 'BIE acompaña la primera implementación con tu cliente para asegurar el éxito.' },
];
---

<BaseLayout
  title="Programa Satélites BIE — Alianzas estratégicas en IA | Ecuador"
  description="Conviértete en satélite BIE. Accede a nuestra infraestructura de IA y ofrece soluciones de primer nivel bajo tu marca a tus propios clientes."
>
  <!-- Hero -->
  <section style="background:#000000; min-height:70vh; display:flex; align-items:center; position:relative; overflow:hidden;" aria-labelledby="sat-heading">
    <div aria-hidden="true" style="position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px); background-size:40px 40px;"></div>
    <div aria-hidden="true" style="position:absolute; inset:0; background:radial-gradient(ellipse 80% 60% at 50% 50%,transparent 40%,rgba(0,0,0,0.65) 100%);"></div>
    <div aria-hidden="true" style="position:absolute; bottom:0; left:0; right:0; height:120px; background:linear-gradient(to bottom,transparent,#fff);"></div>
    <!-- Decorative orbital rings -->
    <div aria-hidden="true" style="position:absolute; right:5%; top:50%; transform:translateY(-50%); width:400px; height:400px; border:1px solid rgba(255,255,255,0.05); border-radius:50%;"></div>
    <div aria-hidden="true" style="position:absolute; right:5%; top:50%; transform:translateY(-50%); width:280px; height:280px; border:1px solid rgba(255,255,255,0.04); border-radius:50%;"></div>
    <div aria-hidden="true" style="position:absolute; right:calc(5% + 60px); top:50%; transform:translateY(-50%); width:40px; height:40px; background:rgba(196,151,42,0.4); border-radius:50%;"></div>
    <div class="ctn" style="position:relative; z-index:1; padding-top:8rem; padding-bottom:9rem; max-width:820px;" data-fade>
      <span class="tag" style="color:rgba(196,151,42,0.8);">Programa Satélites</span>
      <h1 id="sat-heading" style="font-size:clamp(2.25rem,6vw,5rem); font-weight:700; letter-spacing:-0.04em; line-height:0.95; color:white; margin:1rem 0 1.5rem;">
        Convierte tu empresa en el hub tecnológico de tu industria.
      </h1>
      <p style="font-size:1.125rem; color:rgba(255,255,255,0.5); line-height:1.7; max-width:52ch; margin-bottom:2rem;">
        Accede a toda la infraestructura de IA de BIE. Ofrécela bajo tu marca. Genera ingresos recurrentes sin invertir en tecnología.
      </p>
      <a
        href="https://wa.me/593998825303?text=Hola%2C+me+interesa+el+Programa+Sat%C3%A9lites+de+BIE.+%C2%BFPueden+darme+m%C3%A1s+informaci%C3%B3n%3F"
        target="_blank" rel="noopener noreferrer"
        class="btn" style="background:white; color:#000; font-weight:700; padding:0.875rem 1.875rem; font-size:0.9375rem;"
      >
        Quiero ser satélite BIE
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- What is it -->
  <section class="sec" style="background:var(--color-bg-primary);" aria-labelledby="what-heading">
    <div class="ctn">
      <div style="display:grid; grid-template-columns:1fr; gap:4rem;" class="sat-2col">
        <div data-fade>
          <span class="tag">Qué es un satélite BIE</span>
          <h2 id="what-heading" style="font-size:clamp(1.75rem,4vw,2.75rem); font-weight:700; letter-spacing:-0.03em; line-height:1.08; color:var(--color-text-primary); margin:0.75rem 0 1.25rem;">
            Tu empresa, potenciada con la infraestructura de BIE.
          </h2>
          <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.75; margin-bottom:1.25rem;">
            Un satélite BIE es una empresa aliada que accede a nuestra plataforma tecnológica — agentes de IA, automatizaciones, base de conocimiento — y la ofrece a sus propios clientes bajo su propia marca.
          </p>
          <p style="font-size:1.0625rem; color:var(--color-text-secondary); line-height:1.75;">
            Es el modelo de negocio más eficiente que existe para empresas de consultoría, agencias y distribuidores que quieren ofrecer IA sin construir la infraestructura desde cero.
          </p>
        </div>
        <div data-fade data-delay="100">
          <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-text-tertiary); margin-bottom:1.25rem;">¿Para quién es este programa?</p>
          <div style="display:flex; flex-direction:column; gap:0;">
            {fits.map(f => (
              <div style="padding:1rem 0; border-bottom:1px solid var(--color-border); font-size:0.9375rem; color:var(--color-text-secondary); display:flex; align-items:center; gap:0.75rem;">
                <span style="width:6px; height:6px; border-radius:50%; background:var(--color-bie-accent); flex-shrink:0;" aria-hidden="true"></span>
                {f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="sec" style="background:var(--color-bg-secondary);" aria-labelledby="benefits-heading">
    <div class="ctn">
      <div style="max-width:560px; margin-bottom:3.5rem;" data-fade>
        <span class="tag">Qué obtienes</span>
        <h2 id="benefits-heading" style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:700; letter-spacing:-0.025em; color:var(--color-text-primary); margin-top:0.75rem;">
          La infraestructura de BIE, lista para usar.
        </h2>
      </div>
      <div style="display:flex; flex-direction:column; gap:0;">
        {benefits.map((b, i) => (
          <div style="padding:2rem 0; border-bottom:1px solid var(--color-border);" class={i === 0 ? 'sat-benefit-first' : ''} data-fade data-delay={String(i * 80)}>
            <h3 style="font-size:1.0625rem; font-weight:600; color:var(--color-text-primary); letter-spacing:-0.01em; margin-bottom:0.5rem;">{b.title}</h3>
            <p style="font-size:0.9375rem; color:var(--color-text-secondary); line-height:1.7; max-width:64ch;">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="sec" style="background:var(--color-bg-primary);" aria-labelledby="process-heading">
    <div class="ctn">
      <div style="max-width:560px; margin-bottom:3.5rem;" data-fade>
        <span class="tag">Proceso de onboarding</span>
        <h2 id="process-heading" style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:700; letter-spacing:-0.025em; color:var(--color-text-primary); margin-top:0.75rem;">
          De interés a primer cliente en 3–4 semanas.
        </h2>
      </div>
      <div style="display:flex; flex-direction:column; gap:0;">
        {steps.map((s, i) => (
          <div style="display:grid; grid-template-columns:3rem 1fr; gap:0 2rem; padding:2rem 0; border-bottom:1px solid var(--color-border);" data-fade data-delay={String(i * 70)}>
            <span style="font-size:0.6875rem; font-weight:700; letter-spacing:0.08em; color:var(--color-text-tertiary); padding-top:0.25rem;">{s.num}</span>
            <div>
              <h3 style="font-size:1.0625rem; font-weight:600; color:var(--color-text-primary); margin-bottom:0.375rem;">{s.title}</h3>
              <p style="font-size:0.9375rem; color:var(--color-text-secondary); line-height:1.65;">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--color-bie-blue); padding:5rem 0;" aria-labelledby="sat-cta-heading">
    <div class="ctn" style="max-width:600px; margin:0 auto; text-align:center;" data-fade>
      <h2 id="sat-cta-heading" style="font-size:clamp(1.75rem,4vw,2.75rem); font-weight:700; letter-spacing:-0.03em; color:white; margin-bottom:1.25rem;">
        ¿Tu empresa califica?
      </h2>
      <p style="font-size:1.0625rem; color:rgba(255,255,255,0.6); line-height:1.7; margin-bottom:2rem;">
        En 48 horas te decimos si hay alineamiento y cuál sería el primer paso.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:0.75rem; justify-content:center;">
        <a
          href="https://wa.me/593998825303?text=Hola%2C+me+interesa+el+Programa+Sat%C3%A9lites+de+BIE.+%C2%BFPodemos+agendar+una+llamada%3F"
          target="_blank" rel="noopener noreferrer"
          class="btn btn-white"
        >Solicitar evaluación gratuita</a>
        <a href="mailto:hola@bie.ec?subject=Programa%20Satélites%20BIE&body=Hola%2C%20me%20interesa%20el%20Programa%20Satélites%20BIE." class="btn btn-outline-white">hola@bie.ec</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (min-width: 1024px) {
    .sat-2col { grid-template-columns: 1fr 1fr !important; align-items: start; }
  }
  .sat-benefit-first { border-top: 1px solid var(--color-border); }
</style>
